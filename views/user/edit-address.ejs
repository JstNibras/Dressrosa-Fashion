<%- include('../layout/header') %>

    <style>
        .add-address-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
        }

        .add-address-title {
            font-size: 20px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .add-address-form-box {
            border: 1px solid #ddd;
            padding: 40px;
            border-radius: 4px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-row {
            display: flex;
            gap: 20px;
        }

        .form-col {
            flex: 1;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            color: #333;
        }

        .form-label .required {
            color: red;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #999;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
        }

        .form-select {
            width: 100%;
            padding: 12px;
            border: 1px solid #999;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="10" height="5" viewBox="0 0 10 5"><path fill="%23333" d="M0 0l5 5 5-5z"/></svg>') no-repeat right 15px center;
            background-size: 10px 5px;
        }

        .btn-submit {
            display: block;
            width: 100%;
            max-width: 300px;
            margin: 30px auto 0;
            padding: 15px;
            background-color: #ff0055;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            text-transform: uppercase;
            text-align: center;
        }

        .btn-submit:hover {
            background-color: #e6004c;
        }
    </style>

    <div class="add-address-container">
        <div class="add-address-title">ADD ADDRESS</div>

        <div class="add-address-form-box">
            <form action="/profile/address/edit/<%= address._id %>" method="POST" novalidate>
                <input type="hidden" name="returnTo" value="<%= returnTo %>">
                <div class="form-row">
                    <div class="form-group form-col">
                        <label>First Name</label>
                        <input type="text" name="firstName"
                            value="<%= locals.oldData?.firstName || locals.address?.firstName || '' %>"
                            class="form-control" required minlength="2">
                        <% if (locals.errors && errors.firstName) { %>
                            <small style="color: #ff0055;">
                                <%= errors.firstName[0] %>
                            </small>
                            <% } %>
                    </div>
                    <div class="form-group form-col">
                        <label>Last Name</label>
                        <input type="text" name="lastName"
                            value="<%= locals.oldData?.lastName || locals.address?.lastName || '' %>"
                            class="form-control" required minlength="1">
                        <% if (locals.errors && errors.lastName) { %>
                            <small style="color: #ff0055;">
                                <%= errors.lastName[0] %>
                            </small>
                            <% } %>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group form-col">
                        <label>Mobile Number</label>
                        <input type="text" name="mobile"
                            value="<%= locals.oldData?.mobile || locals.address?.mobile || '' %>" class="form-control" required pattern="[0-9]{10}">
                        <% if (locals.errors && errors.mobile) { %>
                            <small style="color: #ff0055;">
                                <%= errors.mobile[0] %>
                            </small>
                            <% } %>
                    </div>
                    <div class="form-group form-col">
                        <label>Pincode</label>
                        <input type="text" name="pincode"
                            value="<%= locals.oldData?.pincode || locals.address?.pincode || '' %>"
                            class="form-control" required pattern="[0-9]{6}">
                        <% if (locals.errors && errors.pincode) { %>
                            <small style="color: #ff0055;">
                                <%= errors.pincode[0] %>
                            </small>
                            <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label>House No., Building Name</label>
                    <input type="text" name="houseNo"
                        value="<%= locals.oldData?.houseNo || locals.address?.houseNo || '' %>" class="form-control" required minlength="3">
                    <% if (locals.errors && errors.houseNo) { %>
                        <small style="color: #ff0055;">
                            <%= errors.houseNo[0] %>
                        </small>
                        <% } %>
                </div>

                <div class="form-row">
                    <div class="form-group form-col">
                        <label>State</label>
                        <input type="text" name="state"
                            value="<%= locals.oldData?.state || locals.address?.state || '' %>" class="form-control" required>
                        <% if (locals.errors && errors.state) { %>
                            <small style="color: #ff0055;">
                                <%= errors.state[0] %>
                            </small>
                            <% } %>
                    </div>
                    <div class="form-group form-col">
                        <label>District</label>
                        <input type="text" name="district"
                            value="<%= locals.oldData?.district || locals.address?.district || '' %>"
                            class="form-control" required>
                        <% if (locals.errors && errors.district) { %>
                            <small style="color: #ff0055;">
                                <%= errors.district[0] %>
                            </small>
                            <% } %>
                    </div>
                    <div class="form-group form-col">
                        <label>City</label>
                        <input type="text" name="city" value="<%= locals.oldData?.city || locals.address?.city || '' %>"
                            class="form-control" required>
                        <% if (locals.errors && errors.city) { %>
                            <small style="color: #ff0055;">
                                <%= errors.city[0] %>
                            </small>
                            <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Address Type</label>
                    <div class="address-type-options" style="display: flex; gap: 20px; margin-top: 10px;">

                        <label style="cursor: pointer;">
                            <input type="radio" name="type" value="HOME" <%=(locals.oldData?.type==='HOME' ||
                                (!locals.oldData?.type && locals.address?.type==='HOME' ) || (!locals.oldData?.type &&
                                !locals.address?.type)) ? 'checked' : '' %>>
                            HOME
                        </label>

                        <label style="cursor: pointer;">
                            <input type="radio" name="type" value="WORK" <%=(locals.oldData?.type==='WORK' ||
                                (!locals.oldData?.type && locals.address?.type==='WORK' )) ? 'checked' : '' %>>
                            WORK
                        </label>

                        <label style="cursor: pointer;">
                            <input type="radio" name="type" value="OTHER" <%=(locals.oldData?.type==='OTHER' ||
                                (!locals.oldData?.type && locals.address?.type==='OTHER' )) ? 'checked' : '' %>>
                            OTHER
                        </label>
                    </div>

                    <% if (locals.errors && errors.type) { %>
                        <small style="color: #ff0055; display: block; margin-top: 5px;">
                            <%= errors.type[0] %>
                        </small>
                        <% } %>
                </div>

                <div style="display: flex; gap: 15px; max-width: 500px; margin: 30px auto 0;">
                    <button type="submit" class="btn-submit" style="margin: 0; flex: 1;">UPDATE ADDRESS</button>
                    <a href="<%= returnTo === 'checkout' ? '/checkout' : '/profile/addresses' %>" 
                       class="btn-submit" 
                       style="margin: 0; flex: 1; background-color: #333; text-decoration: none; display: flex; align-items: center; justify-content: center;">
                        CANCEL
                    </a>
                </div>
            </form>
        </div>
    </div>

    <%- include('../layout/footer') %>

    <script>
        // --- REAL-TIME FIELD-WISE VALIDATION ---
        const form = document.querySelector('form');
        const inputs = form.querySelectorAll('input[type="text"], input[type="radio"]');

        const validationRules = {
            firstName: { 
                test: val => val.trim().length >= 2 && /^[a-zA-Z]+$/.test(val.trim()),
                message: "First name must be at least 2 letters"
            },
            lastName: { 
                test: val => val.trim().length >= 1 && /^[a-zA-Z]+$/.test(val.trim()),
                message: "Last name must be letters only"
            },
            mobile: { 
                test: val => /^[0-9]{10}$/.test(val.trim()),
                message: "Enter a valid 10-digit mobile number"
            },
            pincode: { 
                test: val => /^[0-9]{6}$/.test(val.trim()),
                message: "Enter a valid 6-digit pincode"
            },
            houseNo: { 
                test: val => val.trim().length >= 3,
                message: "House No. must be at least 3 characters"
            },
            state: { test: val => val.trim() !== "", message: "State is required" },
            district: { test: val => val.trim() !== "", message: "District is required" },
            city: { test: val => val.trim() !== "", message: "City is required" }
        };

        function showError(input, message) {
            let errorMsg = input.parentElement.querySelector('small');
            if (!errorMsg) {
                errorMsg = document.createElement('small');
                errorMsg.style.color = '#ff0055';
                errorMsg.style.display = 'block';
                errorMsg.style.marginTop = '5px';
                input.parentElement.appendChild(errorMsg);
            }
            errorMsg.innerText = message;
            input.style.borderColor = '#ff0055';
        }

        function clearError(input) {
            const errorMsg = input.parentElement.querySelector('small');
            if (errorMsg) errorMsg.innerText = '';
            input.style.borderColor = '#999';
        }

        inputs.forEach(input => {
            input.addEventListener('blur', () => {
                const rule = validationRules[input.name];
                if (rule) {
                    if (!rule.test(input.value)) {
                        showError(input, rule.message);
                    } else {
                        clearError(input);
                    }
                }
            });

            input.addEventListener('input', () => {
                const rule = validationRules[input.name];
                if (rule && rule.test(input.value)) {
                    clearError(input);
                }
            });
        });

        // --- PINCODE AUTO-FILL ENGINE ---
        document.querySelector('input[name="pincode"]').addEventListener('input', async function (e) {
            const pincode = e.target.value.trim();

            if (pincode.length === 6 && /^\d+$/.test(pincode)) {
                const districtField = document.querySelector('input[name="district"]');
                const stateField = document.querySelector('input[name="state"]');
                const cityField = document.querySelector('input[name="city"]');

                try {
                    districtField.placeholder = "Loading...";
                    stateField.placeholder = "Loading...";

                    const response = await fetch(`https://api.postalpincode.in/pincode/${pincode}`);
                    const data = await response.json();

                    if (Array.isArray(data) && data.length > 0 && data[0].Status === "Success") {
                        const info = data[0].PostOffice[0];
                        
                        districtField.value = info.District || "";
                        stateField.value = info.State || "";
                        cityField.value = info.Block !== "Not Available" ? info.Block : info.Name;
                        
                        // Clear errors once filled
                        clearError(districtField);
                        clearError(stateField);
                        clearError(cityField);
                    }
                } catch (error) {
                    console.error("Pincode Fetch Error:", error);
                }
            }
        });

        form.addEventListener('submit', (e) => {
            let isValid = true;
            Object.keys(validationRules).forEach(name => {
                const input = form.querySelector(`[name="${name}"]`);
                if (input) {
                    if (!validationRules[name].test(input.value)) {
                        showError(input, validationRules[name].message);
                        isValid = false;
                    }
                }
            });

            if (!isValid) {
                e.preventDefault();
                Swal.fire({
                    icon: 'error',
                    title: 'Wait!',
                    text: 'Please fix the errors in the form before submitting.',
                    confirmButtonColor: '#ff0055'
                });
            }
        });
    </script>