<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart - Dressrosa</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/cart.css">
    <style>
        .cart-item-card.unavailable { opacity: 0.6; border: 1px dashed #e74c3c; background: #fffcfc; }
        .cart-item-card.unavailable .select-box select { pointer-events: none; background: #eee; }
        .item-status-msg { font-size: 12px; font-weight: 600; margin-top: 8px; }
        .text-error { color: #e74c3c; }
    </style>
</head>
<body>
    <%- include('../layout/header') %>

    <div style="max-width: 1200px; margin: 30px auto 0; padding: 0 20px;">
        <h2 style="font-size: 26px; font-weight: 700; color: #111; margin: 0;">Shopping Cart</h2>
    </div>

    <div class="cart-wrapper">
        <% if (cartItems.length > 0) { %>
            <div class="cart-left">
                    
                <% cartItems.forEach(item => { %>
                    <div class="cart-item-card <%= item.isUnavailable ? 'unavailable' : '' %> <%= item.isOutOfStock ? 'oos-dim' : '' %>">
                        <div class="cart-item-main">
                            <div class="cart-item-img">
                                <a href="/product/<%= item.productId %>">
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                </a>
                            </div>
                            
                            <div class="cart-item-info">
                                <div class="info-top">
                                    <h3 class="item-title"><%= item.name %></h3>
                                    <span class="item-total-price">₹ <%= item.price %></span>
                                </div>
                                
                                <div class="item-price-col">
                                    <% if (item.regularPrice > item.price) { %>
                                        <span class="sale-price">₹ <%= item.price %></span>
                                        <span class="regular-price">₹ <%= item.regularPrice %></span>
                                        <span class="offer-text"><%= Math.round(((item.regularPrice - item.price) / item.regularPrice) * 100) %>% OFF</span>
                                    <% } else { %>
                                        <span class="sale-price">₹ <%= item.price %></span>
                                    <% } %>
                                    <span class="mrp-text">MRP</span>
                                </div>
                                <p class="item-category"><%= item.categoryName %></p>
                                
                                <div class="item-selectors">
                                    <div class="select-box">
                                        <label>Size:</label>
                                        <select class="size-select" onchange="updateCartSize('<%= item._id %>', this.value)" <%= item.isUnavailable ? 'disabled' : '' %>>
                                            <% if (item.availableSizes) { %>
                                                <% item.availableSizes.forEach(v => { %>
                                                    <option value="<%= v.size %>" <%= item.size === v.size ? 'selected' : '' %> <%= v.stock === 0 ? 'disabled' : '' %>>
                                                        <%= v.size %> <%= v.stock === 0 ? '(OOS)' : '' %>
                                                    </option>
                                                <% }) %>
                                            <% } else { %>
                                                <option selected disabled>N/A</option>
                                            <% } %>
                                        </select>
                                    </div>
                                    <div class="select-box">
                                        <label>Qty:</label>
                                        <select class="qty-select" onchange="updateCartQty('<%= item._id %>', this.value)" <%= (item.isOutOfStock || item.isUnavailable) ? 'disabled' : '' %>>
                                            <% const maxQty = Math.min(5, item.liveStock > 0 ? item.liveStock : 1); %>
                                            <% for(let i=1; i<=maxQty; i++) { %>
                                                <option value="<%= i %>" <%= item.quantity === i ? 'selected' : '' %>><%= i %></option>
                                            <% } %>
                                        </select>
                                    </div>
                                </div>

                                <% if (item.isBlocked) { %>
                                    <p class="item-status-msg text-error"><i class="fas fa-ban"></i> This product is currently unavailable.</p>
                                <% } else if (item.isDeleted) { %>
                                    <p class="item-status-msg text-error"><i class="fas fa-trash-alt"></i> This product has been removed.</p>
                                <% } else if (item.isOutOfStock) { %>
                                    <p class="item-status-msg text-error"><i class="fas fa-exclamation-circle"></i> Out of Stock</p>
                                <% } else if (item.hasStockIssue) { %>
                                    <p class="item-status-msg text-error"><i class="fas fa-exclamation-circle"></i> Only <%= item.liveStock %> left in stock!</p>
                                <% } %>
                            </div>
                        </div>

                        <div class="cart-item-actions">
                            <button class="btn-action" onclick="removeCartItem('<%= item._id %>')">REMOVE</button>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- RIGHT COLUMN: Billing -->
            <div class="cart-right">
                <!-- <button class="btn-checkout" onclick="window.location.href='/checkout'" style="width: 100%; padding: 15px; background: #00827f; color: white; border: none; font-weight: bold; cursor: pointer; border-radius: 4px;">
                    PLACE ORDER
                </button> -->
                <!-- Accordions
                <div class="accordion-box">
                    <div class="accordion-header"><i class="fas fa-tag"></i> Apply Coupon <i class="fas fa-chevron-down right-icon"></i></div>
                </div>
                <div class="accordion-box mb-15">
                    <div class="accordion-header"><i class="fas fa-wallet"></i> Wallet Money <i class="fas fa-chevron-down right-icon"></i></div>
                </div> -->

                <!-- Billing Summary -->
                <div class="billing-card">
                    <h4>BILLING DETAILS</h4>
                    <div class="billing-row">
                        <span>Cart Total</span>
                        <span>₹ <%= regularTotal.toFixed(2) %></span>
                    </div>
                    <div class="billing-row">
                        <span>Discount</span>
                        <span class="text-teal">- ₹ <%= productDiscount.toFixed(2) %></span>
                    </div>
                    <div class="billing-row">
                        <span>Shipping Charges</span>
                        <span class="text-teal">Free</span>
                    </div>
                    <hr class="divider">
                    <div class="billing-row total-row">
                        <span>Total Amount</span>
                        <span>₹ <%= cartTotal.toFixed(2) %></span>
                    </div>
                </div>
                <br>
                <% if (typeof hasInvalidItems !== 'undefined' && hasInvalidItems) { %>
                <div style="background-color: #fce4e4; border: 1px solid #fccacb; color: #cc0033; padding: 12px; border-radius: 6px; margin-bottom: 15px; font-size: 13px;">
                    <i class="fas fa-exclamation-triangle"></i> 
                    <strong>Attention:</strong> One or more items in your cart are no longer available. Please remove them to proceed.
                </div>
                
                <button type="button" style="width: 100%; padding: 12px; background: #cccccc; color: #666; border: none; border-radius: 6px; cursor: not-allowed; font-weight: bold;">
                    Checkout Disabled
                </button>
            <% } else { %>
                <a href="/checkout" style="display: block; width: 100%; text-align: center; padding: 12px; background: #00827f; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;">
                    Proceed to Checkout
                </a>
            <% } %>
            </div>

        <% } else { %>
            <div class="empty-cart-state">
                <i class="fas fa-shopping-cart"></i>
                <h2>Your cart is empty</h2>
                <button onclick="window.location.href='/shop'" class="btn-primary" style="width: auto; padding: 10px 30px;">Continue Shopping</button>
            </div>
        <% } %>
    </div>

    <%- include('../layout/footer') %>

    <div id="addressModal" class="address-modal-overlay" style="display: none;">
        <div class="address-modal-content">
            <div class="modal-header">
                <h3>Select Delivery Address</h3>
                <button class="close-btn" onclick="closeAddressModal()"><i class="fas fa-times"></i></button>
            </div>
            
            <div class="modal-body">
                <% if (addresses && addresses.length > 0) { %>
                    <% addresses.forEach(addr => { %>
                        <div class="address-card" id="addr-card-<%= addr._id %>">
                            <div class="addr-info">
                                <h4><%= addr.firstName %> <%= addr.lastName %> <span class="badge"><%= addr.type %></span></h4>
                                <p><%= addr.houseNo %></p>
                                <p><%= addr.city %>, <%= addr.district %>, <%= addr.state %> - <%= addr.pincode %></p>
                                <p>Phone: <%= addr.mobile %></p>
                            </div>
                            <div class="addr-actions">
                                <button class="btn-primary" onclick="selectAddress(
                                    '<%= addr._id %>', 
                                    '<%= addr.firstName %> <%= addr.lastName %>', 
                                    '<%= addr.pincode %>', 
                                    '<%= addr.houseNo %>', 
                                    '<%= addr.city %>', 
                                    '<%= addr.district %>',
                                    '<%= addr.state %>'
                                )">DELIVER HERE</button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
                <button class="btn-outline-block mt-15" onclick="window.location.href='/profile/addresses'">+ ADD NEW ADDRESS</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function updateCartSize(itemId, newSize) {
            try {
                const response = await fetch('/cart/update-size', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ itemId, newSize })
                });
                const data = await response.json();

                if (data.success) {
                    window.location.reload(); 
                } else {
                    Swal.fire({ icon: 'error', title: 'Oops...', text: data.message });
                    setTimeout(() => window.location.reload(), 1500);
                }
            } catch (error) {
                console.error(error);
            }
        }

        async function updateCartQty(itemId, newQuantity) {
            try {
                const response = await fetch('/cart/update-quantity', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ itemId, quantity: newQuantity })
                });
                const data = await response.json();

                if (data.success) {
                    // Reload to recalculate all complex GST & Totals
                    window.location.reload(); 
                } else {
                    Swal.fire({ icon: 'error', title: 'Oops...', text: data.message });
                    // Reset the dropdown to previous value by reloading
                    setTimeout(() => window.location.reload(), 1500);
                }
            } catch (error) {
                console.error(error);
            }
        }

        // 2. Handle Item Removal
        function removeCartItem(itemId) {
            Swal.fire({
                title: 'Remove Item?',
                text: "Are you sure you want to remove this from your cart?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#00827f',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, remove it!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch('/cart/remove', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ itemId })
                        });
                        const data = await response.json();
                        
                        if (data.success) window.location.reload();
                    } catch (error) {
                        console.error(error);
                    }
                }
            });
        }

        // Address Modal Engine
        function openAddressModal() {
            document.getElementById('addressModal').style.display = 'flex';
        }

        function closeAddressModal() {
            document.getElementById('addressModal').style.display = 'none';
        }

        function selectAddress(id, fullName, pincode, houseNo, city, district, state) {
            const namePinEl = document.getElementById('display-name-pin');
            const fullAddressEl = document.getElementById('display-full-address');
            
            namePinEl.innerHTML = `Deliver To: ${fullName}, ${pincode}`;
            namePinEl.setAttribute('data-address-id', id);
            
            fullAddressEl.innerHTML = `${houseNo}, ${city}, ${district}, ${state}`;
            
            closeAddressModal();
            
            Swal.fire({
                toast: true, position: 'top-end', icon: 'success',
                title: 'Delivery address updated', showConfirmButton: false, timer: 1500
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Read the URL parameters
            const urlParams = new URLSearchParams(window.location.search);
            const errorMsg = urlParams.get('error');

            // If an error exists, show it, then clean the URL
            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: 'Checkout Blocked',
                    text: errorMsg,
                    confirmButtonColor: '#00827f'
                }).then(() => {
                    // This cleans the '?error=...' out of the URL bar so it doesn't pop up again on refresh
                    window.history.replaceState({}, document.title, window.location.pathname);
                });
            }
        });
    </script>
</body>
</html>