<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dressrosa - Forgot Password</title>
    <link rel="stylesheet" href="/css/forgot-password.css">
</head>
<body>
    <main class="forgot-password-main">
        <div class="form-box">
            
            <header class="box-header">
                <h1>DRESSROSA</h1>
                <p>F A S H I O N</p>
            </header>

            <h2>Forgot Password ?</h2>
            <p class="instruction-text">Enter your email to receive a 4-digit OTP</p>

            <form action="/forgot-password" method="POST">
                <div class="form-group">
                    <label for="email">Email <span class="required">*</span></label>
                    <input type="text" name="email" value="<%= locals.oldData?.email || '' %>">
                    <% if (locals.errors?.email) { %>
                        <small class="error-text"><%= errors.email[0] %></small>
                    <% } %>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">Send OTP</button>
                </div>
            </form>

            <div class="back-link">
                Go to <a href="/login">Sign In</a>
            </div>

        </div>
    </main>
</body>
</html>