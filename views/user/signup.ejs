<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dressrosa - User Sign Up</title>
    <link rel="stylesheet" href="/css/user-signup.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <header class="brand-header">
        <h1>DRESSROSA</h1>
        <p>F A S H I O N</p>
    </header>

    <main class="signup-main">
        <div class="signup-box">
            <h2>Sign Up</h2>

            <form action="/signup" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name</label>
                        <input type="text" name="firstName" 
                        value="<%= locals.oldData?.firstName || '' %>" 
                        class="form-control <%= locals.errors?.firstname ? 'is-invalid' : '' %>">

                        <% if (locals.errors && errors.firstName) { %>
                            <small style="color: #ff0055; font-size: 12px;"><%= errors.firstName[0] %></small>                        
                        <% } %>
                    </div>
                    <div class="form-group">
                        <label>Last Name</label>
                        <input type="text" name="lastName" 
                            value="<%= locals.oldData?.lastName || '' %>" 
                            class="form-control <%= locals.errors?.lastName ? 'is-invalid' : '' %>">
                        
                        <% if (locals.errors && errors.lastName) { %>
                            <small style="color: #ff0055; font-size: 12px;"><%= errors.lastName[0] %></small>
                        <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label>Phone</label>
                    <input type="text" name="phone" 
                        value="<%= locals.oldData?.phone || '' %>" 
                        class="form-control <%= locals.errors?.phone ? 'is-invalid' : '' %>">
                    
                    <% if (locals.errors && errors.phone) { %>
                        <small style="color: #ff0055; font-size: 12px;"><%= errors.phone[0] %></small>
                    <% } %>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="text" name="email" 
                        value="<%= locals.oldData?.email || '' %>" 
                        class="form-control <%= locals.errors?.email ? 'is-invalid' : '' %>">
                    
                    <% if (locals.errors && errors.email) { %>
                        <small style="color: #ff0055; font-size: 12px;"><%= errors.email[0] %></small>
                    <% } %>
                </div>

                <div class="form-group">
                    <label class="form-label">Enter Password</label>
                    <div style="position: relative;">
                        <input type="password" name="password" id="password" 
                            value="<%= locals.oldData?.password || '' %>" 
                            class="form-control <%= locals.errors?.password ? 'is-invalid' : '' %>">
                        <i class="fas fa-eye toggle-icon" data-target="password"
                            style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #666;">
                        </i>
                        <% if (locals.errors && errors.password) { %>
                            <small style="color: #ff0055; font-size: 12px;"><%= errors.password[0] %></small>
                        <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm Password</label>
                    <div style="position: relative;">
                        <input type="password" name="confirmPassword" id="confirmPassword" 
                            value="<%= locals.oldData?.confirmPassword || '' %>" 
                            class="form-control <%= locals.errors?.confirmPassword ? 'is-invalid' : '' %>">
                        <i class="fas fa-eye toggle-icon" data-target="confirmPassword"
                            style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #666;">
                        </i>
                        <% if (locals.errors && errors.confirmPassword) { %>
                            <small style="color: #ff0055; font-size: 12px;"><%= errors.confirmPassword[0] %></small>
                        <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label for="referralCode">Referal Code</label>
                    <input type="text" id="referralCode" name="referralCode" placeholder="Optional">
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-signup">Sign Up</button>
                </div>
            </form>

            <div class="login-prompt">
                Already have an account? <a href="/login">Login</a>
            </div>
        </div>
    </main>
</body>

<script>
    document.querySelectorAll('.toggle-icon').forEach(icon => {
        icon.addEventListener('click', function () {
            const targetId = this.getAttribute('data-target');
            const input = document.getElementById(targetId);

            const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
            input.setAttribute('type', type);
            
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });
    });
</script>

</html>