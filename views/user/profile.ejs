<%- include('../layout/header') %>

<style>
/* Add your custom styles here matching the design */
.profile-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 20px;
}
.profile-card {
    border: 1px solid #ddd;
    padding: 40px;
    text-align: center;
    position: relative;
    border-radius: 4px;
}
.profile-title {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 30px;
}
.profile-info {
    text-align: left;
    margin-top: 30px;
    font-size: 16px;
    line-height: 1.8;
}
.edit-icon {
    position: absolute;
    top: 40px;
    right: 40px;
    font-size: 20px;
    color: #333;
    text-decoration: none;
}
.action-buttons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
}
.action-btn {
    display: inline-block;
    padding: 15px;
    border: 1px solid #333;
    text-align: center;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: bold;
    color: #333;
    text-decoration: none;
    transition: all 0.3s ease;
}
.action-btn:hover {
    background-color: #333;
    color: #fff;
}
.btn-change-pw {
        display: inline-flex; /* Ensures the button only takes up as much space as its text */
        align-items: center;
        gap: 8px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        color: #ff0055;
        border: 1px solid #ff0055;
        padding: 6px 12px;
        border-radius: 4px;
        transition: all 0.2s ease-in-out;
    }

    .btn-change-pw:hover {
        background-color: #ff0055;
        color: #ffffff;
        box-shadow: 0 2px 5px rgba(255, 0, 85, 0.2);
    }
</style>

<div class="profile-container">
    <div class="profile-card">
        <div class="profile-title">User Profile</div>
        
        <i class="fas fa-user" style="font-size: 60px; margin-bottom: 20px;"></i>
        <a href="/profile/edit" class="edit-icon"><i class="fas fa-pencil-alt"></i></a>
        

        <div class="profile-info">
    <p><strong>Full Name :</strong> <%= user.firstName %> <%= user.lastName %></p>
    <p><strong>Email :</strong> <%= user.email %></p>
    <% if (defaultAddress) { %>
        <p><strong>Default Address :</strong> <%= defaultAddress.houseNo %> <%= defaultAddress.city %>, <%= defaultAddress.state %>, <%= defaultAddress.pincode %></p>
    <% } else { %>
        <p><strong>Default Address :</strong> Not set</p>
    <% } %>
    <p><strong>Mobile No. :</strong> <%= user.phone || 'Not set' %></p>

    <div style="display: flex; justify-content: flex-end; width: 100%; margin-top: 10px;">
        <a href="/profile/change-password" class="btn-change-pw">
            <i class="fas fa-key"></i> Change Password
        </a>
    </div>
</div>
        
    </div>

    <div class="action-buttons">
        <a href="/orders" class="action-btn">MY ORDERS</a>
        <a href="/wishlist" class="action-btn">MY WISHLIST</a>
        <a href="/profile/addresses" class="action-btn">EDIT / CHANGE ADDRESS</a>
        <a href="/wallet" class="action-btn">WALLET</a>
        <a href="/coupons" class="action-btn">MY COUPON</a>
        <a href="/referrals" class="action-btn">REFER AND EARN</a>
    </div>
</div>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<%- include('../layout/footer') %>
