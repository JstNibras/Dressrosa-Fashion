<%- include('../layout/header') %>

    <style>
        /* Modal Overlay */
        .modal-overlay {
            display: none; 
            position: fixed; 
            top: 0; 
            left: 0; 
            width: 100%; 
            height: 100%; 
            background: rgba(0, 0, 0, 0.6); 
            backdrop-filter: blur(3px); /* Modern blur effect */
            z-index: 2000;
            transition: all 0.3s ease;
        }

        /* Modal Content Box */
        .modal-content {
            background: #fff; 
            width: 90%; 
            max-width: 400px; 
            margin: 100px auto; 
            padding: 30px; 
            border-radius: 8px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            position: relative;
            text-align: center;
        }

        .modal-content h3 {
            margin-top: 0;
            font-size: 1.2rem;
            color: #333;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .modal-content p {
            font-size: 14px;
            color: #666;
            margin-bottom: 20px;
        }

        /* Form Styling inside Modal */
        .modal-content .form-control {
            margin-bottom: 20px;
            border: 1px solid #ddd;
            transition: border-color 0.3s;
        }

        .modal-content .form-control:focus {
            border-color: #ff0055;
            outline: none;
        }

        /* Button Group */
        .modal-btn-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .btn-send-otp {
            background-color: #ff0055;
            color: white;
            padding: 12px;
            border: none;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            text-transform: uppercase;
        }

        .btn-cancel {
            background: none;
            border: 1px solid #ddd;
            color: #666;
            padding: 10px;
            border-radius: 4px;
            cursor: pointer;
        }

        .btn-cancel:hover {
            background-color: #f5f5f5;
        }
        .edit-profile-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 20px;
        }

        .edit-profile-title {
            font-size: 20px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .edit-profile-card {
            border: 1px solid #ddd;
            padding: 40px;
            border-radius: 4px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-row {
            display: flex;
            gap: 20px;
        }

        .form-col {
            flex: 1;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            color: #333;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            box-sizing: border-box;
            /* Ensure padding doesn't increase width */
        }

        .btn-update {
            display: block;
            width: 100%;
            max-width: 300px;
            margin: 30px auto 15px;
            padding: 15px;
            background-color: #ff0055;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            text-transform: uppercase;
        }

        .btn-update:hover {
            background-color: #e6004c;
        }

        .reset-link {
            text-align: center;
            font-size: 14px;
        }

        .reset-link a {
            color: #0066cc;
            text-decoration: none;
        }

        .reset-link a:hover {
            text-decoration: underline;
        }
    </style>

    <div class="edit-profile-container">
        <div class="edit-profile-title">EDIT PROFILE</div>

        <div class="edit-profile-card">
            <i class="fas fa-user" style="font-size: 60px; margin-bottom: 30px; display: block;"></i>

            <form action="/profile/edit" method="POST">
                <div class="form-row">
                    <div class="form-group form-col">
                        <label class="form-label">First Name</label>
                        <input type="text" name="firstName" class="form-control" value="<%= user.firstName %>">
                        <% if (locals.errors && errors.firstName) { %>
                            <small style="color: #ff0055;"><%= errors.firstName[0] %></small>
                        <% } %>
                    </div>
                    <div class="form-group form-col">
                        <label class="form-label">Last Name</label>
                        <input type="text" name="lastName" class="form-control" value="<%= user.lastName %>">
                        <% if (locals.errors && errors.lastName) { %>
                            <small style="color: #ff0055;"><%= errors.lastName[0] %></small>
                        <% } %>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Mobile</label>
                    <input type="text" name="phone" class="form-control" value="<%= user.phone %>">
                    <% if (locals.errors && errors.phone) { %>
                        <small style="color: #ff0055;"><%= errors.phone[0] %></small>
                    <% } %>
                </div>

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div style="position: relative;">
                        <input type="email" value="<%= user.email %>" class="form-control" readonly style="background-color: #f9f9f9; padding-right: 80px;">
                        <a href="javascript:void(0)" onclick="showEmailChangeModal()" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #ff0050; font-weight: bold; font-size: 12px; text-decoration: none;">
                            CHANGE
                        </a>
                    </div>
                </div>

                

                <button type="submit" class="btn-update">Update</button>
                <div class="reset-link">
                    Forgot Password? <a href="/forgot-password">Reset</a>
                </div>
            </form>
            <div id="emailModal" class="modal-overlay">
                <div class="modal-content">
                    <h3>Change Email</h3>
                    <p>We'll send a 4-digit verification code to your new email address.</p>
                    
                    <form action="/profile/change-email-request" method="POST">
                        <input type="email" name="newEmail" placeholder="Enter new email address" required class="form-control">
                        
                        <div class="modal-btn-group">
                            <button type="submit" class="btn-send-otp">Send OTP</button>
                            <button type="button" onclick="closeModal()" class="btn-cancel">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showEmailChangeModal() { document.getElementById('emailModal').style.display = 'block'; }
        function closeModal() { document.getElementById('emailModal').style.display = 'none'; }
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <%- include('../layout/footer') %>