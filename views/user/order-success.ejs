<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart - Dressrosa</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/order-success.css">
</head>
<body>
    <%- include('../layout/header') %>

    <div class="success-container">
    <div class="success-icon-wrapper">
        <i class="fas fa-check-circle"></i>
    </div>
    
    <h1 class="success-title">Order Placed Successfully!</h1>
    <p class="success-message">
        Thank you for shopping with Dressrosa. Your order has been confirmed and is now being processed.
    </p>
    
    <div class="order-id-box">
        <span style="color: #888; font-size: 14px; text-transform: uppercase;">Order Reference ID</span><br>
        <strong style="font-size: 18px; color: #111;"><%= orderId %></strong>
    </div>
    
    <div class="action-buttons">
        <a href="/profile/orders" class="btn-secondary-custom">VIEW ORDER DETAILS</a>
        <a href="/shop" class="btn-primary-custom">CONTINUE SHOPPING</a>
    </div>
</div>

<%- include('../layout/footer') %>

</body>
</html>