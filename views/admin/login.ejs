<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dressrosa Admin Login</title>
    <link rel="stylesheet" href="/css/admin-login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <header class="brand-header">
        <h1>DRESSROSA</h1>
        <p>F A S H I O N</p>
    </header>
    
    <div class="admin-title-bar">
        <h2>ADMIN LOGIN</h2>
    </div>
    
    <main class="login-main">
        <div class="login-form-box">
            <h3>Log In</h3>
            <% if (locals.error) { %>
                <div class="alert-error" style="color: red; margin-bottom: 10px;"><%= error %></div>
            <% } %>
            <form action="/admin/login" method="POST">
                <div class="form-group">
                    <label for="username">USERNAME <span class="required-asterisk">*</span></label>
                    <input type="text" id="username" name="username" value="<%= locals.oldData ? oldData.username : '' %>">
                    <% if (locals.errors && errors.username) { %>
                        <small style="color: #ff4d4d;"><%= errors.username[0] %></small>
                    <% } %>
                </div>
                
                <div class="form-group">
                    <label for="password">PASSWORD <span class="required-asterisk">*</span></label>
                    <div style="position: relative;">
                        <input type="password" id="password" name="password" style="width: 100%;">
                        <i class="fas fa-eye toggle-icon" data-target="password"
                            style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #666;">
                        </i>
                    </div>
                    <% if (locals.errors && errors.password) { %>
                        <small style="color: #ff4d4d;"><%= errors.password[0] %></small>
                    <% } %>
                </div>

                <% if (locals.error) { %>
                    <div class="alert-error" style="color: #ff4d4d; margin-bottom: 15px; text-align: center;">
                        <%= error %>
                    </div>
                <% } %>
                
                <div class="form-actions">
                    <button type="submit" class="btn-submit">Log In</button>
                </div>
            </form>
        </div>
    </main>
    <script>
        document.querySelectorAll('.toggle-icon').forEach(icon => {
            icon.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const input = document.getElementById(targetId);

                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                
                this.classList.toggle('fa-eye');
                this.classList.toggle('fa-eye-slash');
            });
        });
    </script>
</body>
</html>