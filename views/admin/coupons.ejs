<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Coupon Management</title>
    <link rel="stylesheet" href="/css/admin-products.css"> 
    <link rel="stylesheet" href="/css/admin-orders.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <style>
        .error-msg {
            color: #d32f2f;
            font-size: 11px;
            margin-top: 4px;
            display: block;
            height: 14px;
        }
        .filter-input.invalid {
            border-color: #d32f2f !important;
        }
    </style>

    <div class="admin-layout">
        
        <aside class="sidebar">
            <div class="brand-logo">
                <h1>DRESSROSA</h1>
                <p>F A S H I O N</p>
            </div>
            <nav class="sidebar-nav">
                <a href="/admin/dashboard" class="nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
                <a href="/admin/users" class="nav-item"><i class="fas fa-users"></i> Users</a>
                <a href="/admin/products" class="nav-item"><i class="fas fa-box"></i> Products</a>
                <a href="/admin/categories" class="nav-item"><i class="fas fa-th-list"></i> Categories</a>
                <a href="/admin/coupons" class="nav-item active"><i class="fas fa-ticket-alt"></i> Coupons</a>
                <a href="/admin/orders" class="nav-item"><i class="fas fa-shopping-cart"></i> Orders</a>
                <a href="/admin/report" class="nav-item"><i class="fas fa-chart-pie"></i> Reports</a>
            </nav>
            <div class="sidebar-footer">
                <a href="/admin/logout" class="nav-item logout-btn">Logout <i class="fas fa-sign-out-alt"></i></a>
            </div>
        </aside>

        <main class="main-content">
            <header class="page-header">
                <h2>Coupon Management</h2>
            </header>

            <div class="admin-dashboard-container" style="padding: 0; background: transparent;">
                
                <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 20px; align-items: start;">
                    
                    <div class="filter-card" style="display: block; margin: 0;">
                        <h3 style="margin-top: 0; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px; color: #111;">Create New Coupon</h3>
                        
                        <form id="createCouponForm" novalidate>
                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Coupon Code</label>
                                <input type="text" id="code" name="code" class="filter-input" style="width: 100%; text-transform: uppercase;" placeholder="e.g. FESTIVE50">
                                <small class="error-msg" id="error-code"></small>
                            </div>

                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Discount Type</label>
                                <select id="discountType" name="discountType" class="filter-select" style="width: 100%;">
                                    <option value="flat">Flat Amount (₹)</option>
                                    <option value="percentage">Percentage (%)</option>
                                </select>
                                <small class="error-msg" id="error-discountType"></small>
                            </div>

                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Discount Value</label>
                                <input type="number" id="discountValue" name="discountValue" class="filter-input" style="width: 100%;">
                                <small class="error-msg" id="error-discountValue"></small>
                            </div>

                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Min. Purchase Amount (₹)</label>
                                <input type="number" id="minPurchaseAmount" name="minPurchaseAmount" class="filter-input" style="width: 100%;">
                                <small class="error-msg" id="error-minPurchaseAmount"></small>
                            </div>

                            <div class="filter-group" id="maxDiscountAmountGroup" style="width: 100%; margin-bottom: 15px; display: none;">
                                <label style="display: block; margin-bottom: 5px;">Max Discount Amount (₹)</label>
                                <input type="number" id="maxDiscountAmount" name="maxDiscountAmount" class="filter-input" style="width: 100%;">
                                <small class="error-msg" id="error-maxDiscountAmount"></small>
                            </div>

                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Expiry Date</label>
                                <input type="date" id="expiryDate" name="expiryDate" class="filter-input" style="width: 100%;">
                                <small class="error-msg" id="error-expiryDate"></small>
                            </div>

                            <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px;">Total Usage Limit (0 = Unlimited)</label>
                                <input type="number" id="totalUsageLimit" name="totalUsageLimit" class="filter-input" style="width: 100%;" value="0">
                                <small class="error-msg" id="error-totalUsageLimit"></small>
                            </div>

                            <button type="submit" class="filter-btn" style="width: 100%; margin-top: 10px; background: #00827f; color: white; border: none;">
                                CREATE COUPON
                            </button>
                        </form>
                    </div>

                    <div class="table-container" style="margin: 0;">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Discount</th>
                                    <th>Min. Purchase</th>
                                    <th>Usage</th>
                                    <th>Max Limit</th>
                                    <th>Expiry Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (coupons.length > 0) { %>
                                    <% coupons.forEach(coupon => { %>
                                        <tr>
                                            <td><strong style="color: #00827f;"><%= coupon.code %></strong></td>
                                            <td>
                                                <%= coupon.discountType === 'percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue %>
                                            </td>
                                            <td>₹<%= coupon.minPurchaseAmount %></td>
                                            <td>
                                                <span style="font-size: 13px; font-weight: 600; color: #111;"><%= coupon.usedCount || 0 %></span>
                                            </td>
                                            <td>
                                                <span style="font-size: 13px; color: #666;"><%= coupon.totalUsageLimit > 0 ? coupon.totalUsageLimit : '∞' %></span>
                                            </td>
                                            <td>
                                                <span style="font-size: 13px; color: #666;">
                                                    <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (new Date(coupon.expiryDate) < new Date()) { %>
                                                    <span style="background: #ffebee; color: #d32f2f; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold;">Expired</span>
                                                <% } else if (coupon.isActive) { %>
                                                    <span style="background: #e8f5e9; color: #2e7d32; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold;">Active</span>
                                                <% } else { %>
                                                    <span style="background: #f5f5f5; color: #666; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold;">Disabled</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <div style="display: flex; gap: 8px;">
                                                    <button onclick="openEditModal('<%= coupon._id %>', '<%= coupon.code %>', '<%= coupon.discountType %>', '<%= coupon.discountValue %>', '<%= coupon.minPurchaseAmount %>', '<%= coupon.maxDiscountAmount || 0 %>', '<%= coupon.expiryDate.toISOString().substring(0, 10) %>', '<%= coupon.totalUsageLimit || 0 %>')" style="background: #f57c00; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600;">
                                                        Edit
                                                    </button>
                                                    
                                                    <button onclick="toggleCoupon('<%= coupon._id %>')" style="background: <%= coupon.isActive ? '#d32f2f' : '#2e7d32' %>; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600;">
                                                        <%= coupon.isActive ? 'Disable' : 'Enable' %>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 40px; color: #888;">No coupons created yet.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <div id="editCouponModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: #fff; padding: 25px; border-radius: 8px; width: 90%; max-width: 450px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
            
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px;">
                <h3 style="margin: 0; color: #111;">Edit Coupon</h3>
                <button type="button" onclick="closeEditModal()" style="background: none; border: none; font-size: 20px; cursor: pointer; color: #555;">&times;</button>
            </div>
            
            <form id="editCouponForm" novalidate>
                <input type="hidden" id="editCouponId">
                
                <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 13px;">Coupon Code</label>
                    <input type="text" id="editCode" name="code" class="filter-input" style="width: 100%; text-transform: uppercase;">
                    <small class="error-msg" id="error-edit-code"></small>
                </div>

                <div class="filter-group" style="width: 100%; margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 13px;">Discount Type</label>
                    <select id="editDiscountType" name="discountType" class="filter-select" style="width: 100%;">
                        <option value="flat">Flat Amount (₹)</option>
                        <option value="percentage">Percentage (%)</option>
                    </select>
                    <small class="error-msg" id="error-edit-discountType"></small>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                    <div class="filter-group" style="width: 100%;">
                        <label style="display: block; margin-bottom: 5px; font-size: 13px;">Discount Value</label>
                        <input type="number" id="editDiscountValue" name="discountValue" class="filter-input" style="width: 100%;">
                        <small class="error-msg" id="error-edit-discountValue"></small>
                    </div>
                    <div class="filter-group" style="width: 100%;">
                        <label style="display: block; margin-bottom: 5px; font-size: 13px;">Min. Purchase</label>
                        <input type="number" id="editMinPurchase" name="minPurchaseAmount" class="filter-input" style="width: 100%;">
                        <small class="error-msg" id="error-edit-minPurchaseAmount"></small>
                    </div>
                </div>

                <div class="filter-group" id="editMaxDiscountGroup" style="width: 100%; margin-bottom: 15px; display: none;">
                    <label style="display: block; margin-bottom: 5px; font-size: 13px;">Max Discount Amount (₹)</label>
                    <input type="number" id="editMaxDiscount" name="maxDiscountAmount" class="filter-input" style="width: 100%;">
                    <small class="error-msg" id="error-edit-maxDiscountAmount"></small>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div class="filter-group" style="width: 100%;">
                        <label style="display: block; margin-bottom: 5px; font-size: 13px;">Expiry Date</label>
                        <input type="date" id="editExpiryDate" name="expiryDate" class="filter-input" style="width: 100%;">
                        <small class="error-msg" id="error-edit-expiryDate"></small>
                    </div>
                    <div class="filter-group" style="width: 100%;">
                        <label style="display: block; margin-bottom: 5px; font-size: 13px;">Usage Limit (0=∞)</label>
                        <input type="number" id="editTotalUsageLimit" name="totalUsageLimit" class="filter-input" style="width: 100%;">
                        <small class="error-msg" id="error-edit-totalUsageLimit"></small>
                    </div>
                </div>

                <button type="submit" class="filter-btn" style="width: 100%; background: #f57c00; color: white; border: none; font-weight: bold;">
                    SAVE CHANGES
                </button>
            </form>
        </div>
    </div>

    <script>
        // --- SET MIN DATE FOR CALENDAR ---
        function setMinDate() {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('expiryDate').setAttribute('min', today);
            document.getElementById('editExpiryDate').setAttribute('min', today);
        }
        setMinDate();

        // --- FIELD-WISE ERROR UTILITY ---
        function clearErrors(formId) {
            const form = document.getElementById(formId);
            form.querySelectorAll('.error-msg').forEach(el => el.innerText = '');
            form.querySelectorAll('.filter-input, .filter-select').forEach(el => el.classList.remove('invalid'));
        }

        function showFieldErrors(formId, errors, prefix = 'error-') {
            clearErrors(formId);
            for (const field in errors) {
                const errorEl = document.getElementById(`${prefix}${field}`);
                const inputEl = document.getElementById(formId === 'createCouponForm' ? field : `edit${field.charAt(0).toUpperCase() + field.slice(1)}`);
                
                if (errorEl) {
                    errorEl.innerText = errors[field][0];
                }
                if (inputEl) {
                    inputEl.classList.add('invalid');
                }
            }
        }

        // --- REAL-TIME VALIDATORS ---
        function setupRealTimeValidation(formId, prefix = 'error-') {
            const form = document.getElementById(formId);
            const inputs = form.querySelectorAll('input, select');

            inputs.forEach(input => {
                input.addEventListener('input', () => {
                    const errorEl = document.getElementById(`${prefix}${input.name}`);
                    if (errorEl && errorEl.innerText) {
                        errorEl.innerText = '';
                        input.classList.remove('invalid');
                    }
                });
            });
        }

        setupRealTimeValidation('createCouponForm', 'error-');
        setupRealTimeValidation('editCouponForm', 'error-edit-');

        // 1. Create Coupon 
        document.getElementById('createCouponForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            clearErrors('createCouponForm');
            
            const payload = {
                code: document.getElementById('code').value,
                discountType: document.getElementById('discountType').value,
                discountValue: document.getElementById('discountValue').value,
                minPurchaseAmount: document.getElementById('minPurchaseAmount').value,
                maxDiscountAmount: document.getElementById('maxDiscountAmount').value,
                expiryDate: document.getElementById('expiryDate').value,
                totalUsageLimit: document.getElementById('totalUsageLimit').value
            };

            try {
                const response = await fetch('/admin/coupons/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await response.json();

                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Success', text: data.message, timer: 1500, showConfirmButton: false })
                    .then(() => window.location.reload());
                } else if (data.errors) {
                    showFieldErrors('createCouponForm', data.errors, 'error-');
                } else {
                    Swal.fire('Error', data.message || 'Something went wrong', 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Server error. Please try again.', 'error');
            }
        });

        // 2. Toggle Status 
        async function toggleCoupon(couponId) {
            try {
                const response = await fetch('/admin/coupons/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ couponId })
                });
                const data = await response.json();

                if (data.success) {
                    window.location.reload();
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch (error) {
                console.error(error);
            }
        }

        document.getElementById('discountType').addEventListener('change', function() {
            if (this.value === 'percentage') {
                document.getElementById('maxDiscountAmountGroup').style.display = 'block';
            } else {
                document.getElementById('maxDiscountAmountGroup').style.display = 'none';
            }
        });

        document.getElementById('editDiscountType').addEventListener('change', function() {
            if (this.value === 'percentage') {
                document.getElementById('editMaxDiscountGroup').style.display = 'block';
            } else {
                document.getElementById('editMaxDiscountGroup').style.display = 'none';
            }
        });

        // --- EDIT MODAL ENGINE ---
        function openEditModal(id, code, type, value, min, max, date, limit) {
            clearErrors('editCouponForm');
            document.getElementById('editCouponId').value = id;
            document.getElementById('editCode').value = code;
            document.getElementById('editDiscountType').value = type;
            document.getElementById('editDiscountValue').value = value;
            document.getElementById('editMinPurchase').value = min;
            document.getElementById('editMaxDiscount').value = max;
            document.getElementById('editExpiryDate').value = date;
            document.getElementById('editTotalUsageLimit').value = limit || 0;

            document.getElementById('editDiscountType').dispatchEvent(new Event('change'));
            document.getElementById('editCouponModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('editCouponModal').style.display = 'none';
        }

        // --- SUBMIT EDIT ---
        document.getElementById('editCouponForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            clearErrors('editCouponForm');
            
            const payload = {
                couponId: document.getElementById('editCouponId').value,
                code: document.getElementById('editCode').value,
                discountType: document.getElementById('editDiscountType').value,
                discountValue: document.getElementById('editDiscountValue').value,
                minPurchaseAmount: document.getElementById('editMinPurchase').value,
                maxDiscountAmount: document.getElementById('editMaxDiscount').value,
                expiryDate: document.getElementById('editExpiryDate').value,
                totalUsageLimit: document.getElementById('editTotalUsageLimit').value
            };

            try {
                const response = await fetch('/admin/coupons/edit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await response.json();

                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Updated!', text: data.message, timer: 1500, showConfirmButton: false })
                    .then(() => window.location.reload());
                } else if (data.errors) {
                    showFieldErrors('editCouponForm', data.errors, 'error-edit-');
                } else {
                    Swal.fire('Error', data.message || 'Something went wrong', 'error');
                }
            } catch (error) {
                Swal.fire('Error', 'Server error. Please try again.', 'error');
            }
        });
    </script>
</body>
</html>