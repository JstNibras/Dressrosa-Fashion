<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Category Management</title>
    <link rel="stylesheet" href="/css/admin-categories.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div class="admin-layout">
        
        <aside class="sidebar">
            <div class="brand-logo">
                <h1>DRESSROSA</h1>
                <p>F A S H I O N</p>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/admin/dashboard" class="nav-item"><i class="fas fa-th-large"></i> Dashboard</a>
                <a href="/admin/users" class="nav-item"><i class="fas fa-users"></i> Users</a>
                <a href="/admin/products" class="nav-item"><i class="fas fa-box"></i> Products</a>
                <a href="/admin/categories" class="nav-item active"><i class="fas fa-th-list"></i> Categories</a>
                <a href="/admin/coupons" class="nav-item"><i class="fas fa-ticket-alt"></i> Coupons</a>
                <a href="/admin/orders" class="nav-item"><i class="fas fa-shopping-cart"></i> Orders</a>
                <a href="/admin/report" class="nav-item"><i class="fas fa-chart-pie"></i> Reports</a>
            </nav>

            <div class="sidebar-footer">
                <a href="/admin/logout" class="nav-item logout-btn">Logout <i class="fas fa-sign-out-alt"></i></a>
            </div>
        </aside>

        <main class="main-content">
            <header class="page-header">
                <h2>CATEGORY MANAGEMENT</h2>
            </header>

            <div class="controls-bar" style="display: flex; justify-content: space-between; align-items: center;">
                
                <form action="/admin/categories" method="GET" style="display: flex; gap: 15px; align-items: center; margin: 0;">
                    
                    <input type="text" name="search" class="form-input search-input" style="width: 250px; background-color: #f1f1f1; border: none;" 
                           value="<%= locals.searchQuery || '' %>" placeholder="Search Categories...">

                    <select name="status" class="form-input filter-select" style="width: 150px; background-color: #f1f1f1; border: none; cursor: pointer;" 
                            onchange="this.form.submit()">
                        <option value="all" <%= locals.statusFilter === 'all' ? 'selected' : '' %>>All Status</option>
                        <option value="active" <%= locals.statusFilter === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="inactive" <%= locals.statusFilter === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    </select>

                    <button type="submit" class="btn-action" style="background-color: #333; color: white;">FILTER</button>
                    
                    <% if ((locals.searchQuery && locals.searchQuery.trim() !== '') || (locals.statusFilter && locals.statusFilter !== 'all')) { %>
                        <a href="/admin/categories" class="btn-action btn-unblock" style="text-decoration: none; display: flex; align-items: center;">RESET</a>
                    <% } %>
                </form>

                <button class="btn-action btn-add-new" onclick="openModal()">+ ADD CATEGORY</button>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>IMAGE</th>
                            <th>CATEGORY NAME</th>
                            <th>OFFER</th>
                            <th>STATUS</th>
                            <th>ACTION</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(category => { %>
                                <tr style="<%= !category.isActive ? 'background-color: #fce4e4;' : '' %>">
                                    <td>
                                        <img src="<%= category.image || '/images/default/default-category.png' %>" class="cat-img" alt="Category">
                                    </td>
                                    <td>
                                        <div class="user-info">
                                            <span><%= category.name %></span>
                                        </div>
                                    </td>
                                    <td><%= category.offerPercentage %>%</td>
                                    <td>
                                        <span id="status-badge-<%= category._id %>" class="<%= category.isActive ? 'badge-active' : 'badge-inactive' %>">
                                            <%= category.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 8px;">
                                            <button class="btn-action" style="background-color: #3085d6; color: white;" 
                                                    onclick="openEditModal('<%= category._id %>', '<%= category.name %>', '<%= category.image || '' %>', '<%= category.offerPercentage || 0 %>')">
                                                EDIT
                                            </button>
                                            
                                            <button id="toggle-btn-<%= category._id %>" 
                                                    class="btn-action <%= category.isActive ? 'btn-block' : 'btn-unblock' %>"
                                                    onclick="toggleCategory('<%= category._id %>', <%= category.isActive %>)">
                                                <%= category.isActive ? 'DEACTIVATE' : 'ACTIVATE' %>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align:center; padding: 20px;">No categories found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (locals.totalPages > 1) { %>
                <div class="pagination">
                    <% if (locals.currentPage > 1) { %>
                        <a href="?page=<%= locals.currentPage - 1 %>&search=<%= locals.searchQuery %>&status=<%= locals.statusFilter %>" class="page-item"><i class="fas fa-chevron-left"></i></a>
                    <% } %>

                    <% for(let i = 1; i <= locals.totalPages; i++) { %>
                        <a href="?page=<%= i %>&search=<%= locals.searchQuery %>&status=<%= locals.statusFilter %>" 
                           class="page-item <%= locals.currentPage == i ? 'active' : '' %>">
                           <%= i %>
                        </a>
                    <% } %>

                    <% if (locals.currentPage < locals.totalPages) { %>
                        <a href="?page=<%= locals.currentPage + 1 %>&search=<%= locals.searchQuery %>&status=<%= locals.statusFilter %>" class="page-item"><i class="fas fa-chevron-right"></i></a>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>

    <div class="modal-overlay" id="categoryModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Add New Category</h3>
                <button type="button" class="close-btn" onclick="closeModal()"><i class="fas fa-times"></i></button>
            </div>
            <form id="addCategoryForm">
                <div class="form-group">
                    <label>Category Name *</label>
                    <input type="text" id="catName" name="name" class="form-input" placeholder="e.g. Men's Sneakers">
                    <span id="add-error-name" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label>Category Offer (%)</label>
                    <input type="number" name="offerPercentage" id="addCatOffer" class="form-input" min="0" max="100" placeholder="e.g., 10">
                    <span id="add-error-offerPercentage" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label style="margin-bottom: 10px; display: block;">Category Image *</label>
                    <div class="image-upload-container">
                        <div class="image-upload-box" style="max-width: 200px;">
                            <input type="file" name="image" id="addCatInput" class="upload-input" accept="image/*" onchange="previewImage(this, 'prevCat', 'labelCat', 'removeCat')">
                            <img id="prevCat" class="upload-preview" src="">
                            <span id="labelCat" class="upload-label">Upload Image</span>
                            <button type="button" id="removeCat" class="remove-image-btn" onclick="clearCategoryImage('image', 'prevCat', 'labelCat', 'removeCat')">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                    <span id="add-error-image" class="error-message"></span>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-action" style="background-color: #888888; color: #fff;" onclick="closeModal()">CANCEL</button>
                    <button type="submit" class="btn-action btn-add-new">SAVE CATEGORY</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="editCategoryModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Edit Category</h3>
                <button type="button" class="close-btn" onclick="closeEditModal()"><i class="fas fa-times"></i></button>
            </div>
            <form id="editCategoryForm">
                <input type="hidden" id="editCatId" name="id">
                <div class="form-group">
                    <label>Category Name *</label>
                    <input type="text" id="editCatName" name="name" class="form-input">
                    <span id="edit-error-name" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label>Category Offer (%)</label>
                    <input type="number" name="offerPercentage" id="editCatOffer" class="form-input" min="0" max="100" placeholder="e.g., 10">
                    <span id="edit-error-offerPercentage" class="error-message"></span>
                </div>
                <div class="form-group">
                    <label style="margin-bottom: 10px; display: block;">Category Image</label>
                    <div class="image-upload-container">
                        <div class="image-upload-box" style="max-width: 200px;">
                            <input type="file" name="image" id="editCatInput" class="upload-input" accept="image/*" onchange="previewImage(this, 'editPrevCat', 'editLabelCat', 'editRemoveCat')">
                            <img id="editPrevCat" class="upload-preview" src="">
                            <span id="editLabelCat" class="upload-label">Change Image</span>
                            <button type="button" id="editRemoveCat" class="remove-image-btn" onclick="clearCategoryImage('image', 'editPrevCat', 'editLabelCat', 'editRemoveCat')">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                    <span id="edit-error-image" class="error-message"></span>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-action" style="background-color: #888888; color: #fff;" onclick="closeEditModal()">CANCEL</button>
                    <button type="submit" class="btn-action" style="background-color: #3085d6; color: #fff;">UPDATE CATEGORY</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="cropModal" style="z-index: 9999; display: none;">
        <div class="modal-content" style="max-width: 600px; background: #fff; padding: 20px; border-radius: 8px;">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                <h3 style="margin: 0;">Crop Category Image</h3>
                <button type="button" class="close-btn" onclick="closeCropModal(true)" style="background: none; border: none; font-size: 20px; cursor: pointer;"><i class="fas fa-times"></i></button>
            </div>
            
            <div style="width: 100%; max-height: 400px; overflow: hidden; margin-bottom: 20px; background: #f8fafc; display: flex; justify-content: center; align-items: center;">
                <img id="imageToCrop" src="" style="max-width: 100%; display: block;">
            </div>
            
            <div class="modal-actions" style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" style="background-color: #888888; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer;" onclick="closeCropModal(true)">CANCEL</button>
                <button type="button" style="background-color: #3085d6; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer;" onclick="executeCrop()">CROP & SAVE</button>
            </div>
        </div>
    </div>

    <script>
        function openModal() { 
            closeModal(); // Ensure full reset before opening
            document.getElementById('categoryModal').style.display = 'flex'; 
        }
        
        function closeModal() { 
            document.getElementById('categoryModal').style.display = 'none'; 
            document.getElementById('addCategoryForm').reset();
            clearErrors('add');
            
            // Reset image previews and buttons
            const prev = document.getElementById('prevCat');
            if (prev) {
                prev.src = '';
                prev.removeAttribute('src');
                prev.style.display = 'none';
            }
            document.getElementById('labelCat').style.display = 'block';
            document.getElementById('removeCat').style.display = 'none';
            
            if (document.getElementById('addCatInput')) {
                document.getElementById('addCatInput').value = '';
            }
        }

        document.getElementById('addCategoryForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!validateCategoryForm('add')) return;

            const form = document.getElementById('addCategoryForm');
            const formData = new FormData(form); 

            try {
                const response = await fetch('/admin/categories/add', {
                    method: 'POST',
                    body: formData 
                });

                const data = await response.json();

                if (data.success) {
                    closeModal();
                    Swal.fire({ icon: 'success', title: 'Success', text: data.message, timer: 1500, showConfirmButton: false })
                    .then(() => location.reload()); 
                } else {
                    if (data.field) {
                        showError(data.field, data.message, 'add');
                    } else {
                        Swal.fire({ icon: 'error', title: 'Oops...', text: data.message });
                    }
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Server error occurred' });
            }
        });

        async function toggleCategory(categoryId, currentStatus) {
            const actionText = currentStatus ? "deactivate" : "activate";
            const isDeactivating = currentStatus;
            
            const result = await Swal.fire({
                title: `Are you sure?`,
                text: `Do you want to ${actionText} this category?`,
                icon: isDeactivating ? 'warning' : 'question',
                showCancelButton: true,
                confirmButtonColor: isDeactivating ? '#e60039' : '#009955',
                cancelButtonColor: '#888',
                confirmButtonText: actionText.toUpperCase(),
                cancelButtonText: 'CANCEL',
                background: '#fff',
                color: '#000'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/categories/toggle/${categoryId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    const data = await response.json();

                    if (data.success) {
                        Swal.fire({ icon: 'success', title: 'Updated!', text: data.message, timer: 1500, showConfirmButton: false });
                        
                        const badge = document.getElementById(`status-badge-${categoryId}`);
                        const btn = document.getElementById(`toggle-btn-${categoryId}`);
                        const row = btn.closest('tr');
                        
                        if (data.isActive) {
                            badge.className = 'badge-active'; badge.innerText = 'Active';
                            btn.className = 'btn-action btn-block'; btn.innerText = 'DEACTIVATE';
                            btn.setAttribute('onclick', `toggleCategory('${categoryId}', true)`);
                            row.style.backgroundColor = '#e2e2e2'; // Match table default
                        } else {
                            badge.className = 'badge-inactive'; badge.innerText = 'Inactive';
                            btn.className = 'btn-action btn-unblock'; btn.innerText = 'ACTIVATE';
                            btn.setAttribute('onclick', `toggleCategory('${categoryId}', false)`);
                            row.style.backgroundColor = '#fce4e4';
                        }
                    } else {
                        Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
                    }
                } catch (error) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Could not connect to server' });
                }
            }
        }

        function openEditModal(id, name, imageUrl, offerPercentage) {
            const preview = document.getElementById('editPrevCat');
            const label = document.getElementById('editLabelCat');
            const removeBtn = document.getElementById('editRemoveCat');
            
            clearErrors('edit');

            if (imageUrl && imageUrl.trim() !== '') {
                preview.src = imageUrl;
                preview.style.display = 'block';
                label.style.display = 'none';
                removeBtn.style.display = 'flex';
            } else {
                preview.src = '';
                preview.removeAttribute('src');
                preview.style.display = 'none';
                label.style.display = 'block';
                removeBtn.style.display = 'none';
            }
            document.getElementById('editCatId').value = id;
            document.getElementById('editCatName').value = name;
            document.getElementById('editCatOffer').value = offerPercentage;
            document.getElementById('editCategoryModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('editCategoryModal').style.display = 'none';
            document.getElementById('editCategoryForm').reset();
            clearErrors('edit');
            
            // Reset image previews and buttons
            const prev = document.getElementById('editPrevCat');
            if (prev) {
                prev.src = '';
                prev.removeAttribute('src');
                prev.style.display = 'none';
            }
            document.getElementById('editLabelCat').style.display = 'block';
            document.getElementById('editRemoveCat').style.display = 'none';
            
            if (document.getElementById('editCatInput')) {
                document.getElementById('editCatInput').value = '';
            }
        }

        document.getElementById('editCategoryForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!validateCategoryForm('edit')) return;

            const form = document.getElementById('editCategoryForm');
            const formData = new FormData(form);
            const categoryId = document.getElementById('editCatId').value;

            try {
                const response = await fetch(`/admin/categories/edit/${categoryId}`, {
                    method: 'POST',
                    body: formData 
                });

                const data = await response.json();

                if (data.success) {
                    closeEditModal();
                    Swal.fire({ icon: 'success', title: 'Updated!', text: data.message, timer: 1500, showConfirmButton: false })
                    .then(() => location.reload()); 
                } else {
                    if (data.field) {
                        showError(data.field, data.message, 'edit');
                    } else {
                        Swal.fire({ icon: 'error', title: 'Oops...', text: data.message });
                    }
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Server error occurred' });
            }
        });

        // --- VALIDATION ENGINE ---
        function showError(field, message, prefix) {
            const errorSpan = document.getElementById(`${prefix}-error-${field}`);
            const input = document.querySelector(`#${prefix}CategoryForm [name="${field}"]`);
            if (errorSpan) errorSpan.innerText = message;
            if (input) input.classList.add('is-invalid');
        }

        function clearErrors(prefix) {
            document.querySelectorAll(`#${prefix}CategoryForm .error-message`).forEach(el => el.innerText = '');
            document.querySelectorAll(`#${prefix}CategoryForm .form-input`).forEach(el => el.classList.remove('is-invalid'));
        }

        function validateCategoryForm(prefix) {
            clearErrors(prefix);
            const form = document.getElementById(`${prefix}CategoryForm`);
            let isValid = true;

            const name = form.querySelector('[name="name"]').value.trim();
            const offerPercentage = form.querySelector('[name="offerPercentage"]').value;

            if (!name) { showError('name', 'Category name is required', prefix); isValid = false; }
            else if (name.length < 3) { showError('name', 'Name must be at least 3 characters', prefix); isValid = false; }

            if (offerPercentage && (Number(offerPercentage) < 0 || Number(offerPercentage) > 100)) {
                showError('offerPercentage', 'Offer must be between 0 and 100', prefix); isValid = false;
            }

            // Image Validation
            const preview = document.getElementById(prefix === 'add' ? 'prevCat' : 'editPrevCat');
            const fileInput = document.getElementById(prefix === 'add' ? 'addCatInput' : 'editCatInput');
            
            const isImagePresent = (preview && preview.style.display === 'block') || (fileInput && fileInput.files.length > 0);

            if (!isImagePresent) {
                const errorSpan = document.getElementById(`${prefix}-error-image`);
                if (errorSpan) errorSpan.innerText = 'Category image is required';
                isValid = false;
            }

            return isValid;
        }

        function clearCategoryImage(inputName, previewId, labelId, removeId) {
            const prefix = previewId.includes('edit') ? 'edit' : 'add';
            const input = document.getElementById(prefix === 'add' ? 'addCatInput' : 'editCatInput');
            if (input) input.value = '';
            
            const preview = document.getElementById(previewId);
            preview.src = '';
            preview.removeAttribute('src');
            preview.style.display = 'none';
            
            document.getElementById(labelId).style.display = 'block';
            document.getElementById(removeId).style.display = 'none';
        }

        // --- HIGH-PRECISION CROPPER ENGINE (CATEGORY) ---
        let cropper; 
        let currentInput; 
        let currentPreviewId; 
        let currentLabelId;

        function previewImage(input, previewId, labelId, removeId) {
            if (input.files && input.files[0]) {
                currentInput = input;
                currentPreviewId = previewId;
                currentLabelId = labelId;
                currentRemoveId = removeId;

                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('imageToCrop').src = e.target.result;
                    document.getElementById('cropModal').style.display = 'flex';
                    
                    if (cropper) cropper.destroy();
                    
                    cropper = new Cropper(document.getElementById('imageToCrop'), {
                        aspectRatio: 1, // 1:1 Square ratio for Category Thumbnails
                        viewMode: 1,
                        autoCropArea: 1,
                        background: false
                    });
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function closeCropModal(isCancel = false) {
            document.getElementById('cropModal').style.display = 'none';
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
            // If they hit cancel, delete the uncropped file they selected
            if (isCancel && currentInput) {
                currentInput.value = ''; 
            }
        }

        function executeCrop() {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({
                width: 600, 
                height: 600
            });

            canvas.toBlob((blob) => {
                const fileName = currentInput.files[0].name;
                const newFile = new File([blob], fileName, { type: 'image/jpeg', lastModified: Date.now() });

                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(newFile);
                
                // 1. Save the file to the input
                currentInput.files = dataTransfer.files;

                // 2. Update the visual UI
                const preview = document.getElementById(currentPreviewId);
                const label = document.getElementById(currentLabelId);
                const removeBtn = document.getElementById(currentRemoveId);
                preview.src = URL.createObjectURL(blob);
                preview.style.display = 'block';
                label.style.display = 'none';
                if (removeBtn) removeBtn.style.display = 'flex';

                // 3. Close the modal safely (passing FALSE so it doesn't wipe our new file!)
                closeCropModal(false);
            }, 'image/jpeg', 0.85); 
        }

        // Function to show the image preview after cropping
        function showCroppedImage(blob, previewId, labelId) {
            // 1. Get references to the preview img and the text label
            const previewElement = document.getElementById(previewId);
            const labelElement = document.getElementById(labelId);

            if (blob) {
                // 2. Create a temporary URL from the image data
                const imageUrl = URL.createObjectURL(blob);

                // 3. Set the preview image's source and make it visible
                previewElement.src = imageUrl;
                previewElement.style.display = 'block';

                // 4. Hide the text label
                labelElement.style.display = 'none';

            } else {
                // If no image is provided, clear the field
                previewElement.src = '';
                previewElement.style.display = 'none';
                labelElement.style.display = 'block';
            }
        }
    </script>
</body>
</html>